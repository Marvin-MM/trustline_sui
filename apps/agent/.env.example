# ============================================================
# BondFlow Agent Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Required variables are marked with [REQUIRED].
# Optional variables have defaults shown after the = sign.

# --- Core ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
EXTERNAL_SERVICES_MODE=mock     # mock for local API dev, live for production/deployed integrations
START_WORKERS=false             # true in production; false lets local API start without Sui/Redis workers

# --- Database [REQUIRED] ---
# PostgreSQL 15+ connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bondflow?schema=public

# --- Redis [REQUIRED] ---
# Redis connection URL for caching, queues, and distributed locks
REDIS_URL=redis://localhost:6379

# --- JWT Dual-Key Rotation [REQUIRED] ---
# Both keys are required. Set PREVIOUS = CURRENT initially.
# To rotate: set CURRENT to new key, PREVIOUS to old key, deploy.
# After all access tokens expire (15m), old key is safe to retire.
JWT_SECRET_CURRENT=             # required — min 32 random bytes, base64 or hex encoded
JWT_SECRET_PREVIOUS=            # required — can equal CURRENT initially
JWT_ACCESS_EXPIRY=15m           # access token TTL
JWT_REFRESH_EXPIRY=7d           # refresh token TTL

# --- Sui Blockchain [REQUIRED] ---
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_PACKAGE_ID=                 # deployed bondflow package object ID (0x...)
SUI_AGENT_PRIVATE_KEY=          # Ed25519 private key for the backend agent wallet (hex or base64)
SUI_PROTOCOL_STATE_ID=          # shared ProtocolState object ID
SUI_ATTESTATION_REGISTRY_ID=    # shared AttestationRegistry object ID
SUI_PROOF_REGISTRY_ID=          # shared ProofRegistry object ID
SUI_REVOKED_CAPS_ID=            # shared RevokedCaps object ID
SUI_REPUTATION_LEDGER_ID=       # shared ReputationLedger object ID
SUI_ADMIN_CAP_ID=                # protocol AdminCap object ID
SUI_NETWORK=testnet             # mainnet | testnet | devnet | localnet
SUI_PAYMENT_COIN_TYPE=          # verified testnet USDC coin type
SUI_PAYMENT_COIN_SYMBOL=USDC
SUI_PAYMENT_COIN_DECIMALS=6
SUI_CONTRACT_VERSION=2

# --- Walrus ---
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
MEMWAL_PRIVATE_KEY=             # optional Ed25519 delegate key for MemWal relayer
MEMWAL_ACCOUNT_ID=              # optional MemWal account object ID
MEMWAL_SERVER_URL=https://relayer.memwal.ai

# --- AI [REQUIRED] ---
GOOGLE_GENERATIVE_AI_API_KEY=   # Google AI Studio API key for Gemini models

# --- Email ---
# Resend is primary. If RESEND_API_KEY is empty, falls back to Gmail SMTP.
RESEND_API_KEY=                 # Resend API key (optional — falls back to Gmail)
RESEND_FROM_EMAIL=noreply@bondflow.io
GMAIL_USER=                     # Gmail address for SMTP fallback
GMAIL_APP_PASSWORD=             # Gmail app password (not regular password)
GMAIL_FROM_EMAIL=               # From address for Gmail fallback

# --- Webhook [REQUIRED] ---
# HMAC-SHA256 secret for webhook signature verification
WEBHOOK_SECRET=                 # min 32 random bytes

# --- CORS ---
# Comma-separated list of allowed origins. Never use *.
ALLOWED_ORIGINS=http://localhost:3001

# --- Observability ---
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_METRICS_ENDPOINT=http://localhost:4318
OTEL_SAMPLE_RATE=1.0            # 0.0 to 1.0 — 100% in dev, configurable in prod
SERVICE_VERSION=0.1.0

# --- Multi-tenancy ---
DEFAULT_TENANT_PLAN=FREE        # FREE | PRO | ENTERPRISE

# --- File Upload Abuse Prevention ---
MAX_UPLOAD_BYTES=52428800       # 50 MB
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/gif,application/zip,text/plain

# --- Circuit Breaker ---
CIRCUIT_RESET_TIMEOUT=60000     # ms — time before HALF_OPEN probe after circuit opens

# --- Data Retention ---
BLOCKCHAIN_EVENT_RETENTION_DAYS=180
AGENT_ACTION_RETENTION_DAYS=90

# --- Scheduler ---
SCHEDULER_CLEANUP_HOUR=2        # UTC hour for daily cleanup (0-23)

# --- Admin ---
ADMIN_WALLET_ADDRESS=           # Platform admin wallet address for seeding

# --- Rate Limiting (requests per minute) ---
RATE_LIMIT_AUTH=10              # Auth endpoints per IP
RATE_LIMIT_UPLOAD=5             # File uploads per user
RATE_LIMIT_AI=20                # AI pipeline per user
RATE_LIMIT_TENANT=30            # Tenant management per user
RATE_LIMIT_GENERAL=100          # General API per user
