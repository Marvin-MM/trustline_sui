    "@elysiajs/opentelemetry": "^1.4.11",
    "@elysiajs/swagger": "^1.3.1",
    "@mysten/sui": "^2.17.0",
    "@mysten-incubation/memwal": "^0.0.6",
    "@opentelemetry/api": "^1.9.0",
